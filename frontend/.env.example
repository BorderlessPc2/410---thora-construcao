# Desenvolvimento local
VITE_API_URL=http://localhost:8001

# Produção (Netlify / Vercel)
# VITE_API_URL=https://your-backend-api-url.com

# Keep-alive Render (frontend Netlify → API Render)
# Ativo automaticamente quando VITE_API_URL contém .onrender.com ou .run.app
# VITE_KEEP_ALIVE_ENABLED=true
# VITE_KEEP_ALIVE_INTERVAL_MS=30000
